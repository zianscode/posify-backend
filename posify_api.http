# =========================================================================
# Warmindo API HTTP Request - REST Client File
# Install the "REST Client" extension (by Huachao Mao) in VS Code/Antigravity IDE
# to enable the "Send Request" buttons above each block.
# =========================================================================

@baseUrl = http://localhost:5000/api/v1

# ==========================================
# 1. AUTENTIKASI
# ==========================================

### Login Admin (Saves token automatically for subsequent requests)
# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "password": "admin123"
}

### Extract Admin Token
@adminToken = {{loginAdmin.response.body.data.accessToken}}
@adminRefreshToken = {{loginAdmin.response.body.data.refreshToken}}


### Login Kasir (only after seed)
# @name loginCashier
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "kasir@gmail.com",
  "password": "admin123"
}

### Extract Kasir Token
@kasirToken = {{loginCashier.response.body.data.accessToken}}


### Refresh Access Token
# @name refreshAdmin
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{adminRefreshToken}}"
}


### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{adminToken}}


# ==========================================
# 2. MASTER KATEGORI (READ-ONLY)
# ==========================================

### List Semua Kategori
GET {{baseUrl}}/categories
Authorization: Bearer {{kasirToken}}


### Detail Kategori Berdasarkan ID
GET {{baseUrl}}/categories/1
Authorization: Bearer {{kasirToken}}


# ==========================================
# 3. MASTER UNIT SATUAN (READ-ONLY)
# ==========================================

### List Semua Unit
GET {{baseUrl}}/units
Authorization: Bearer {{kasirToken}}


### Detail Unit Berdasarkan ID
GET {{baseUrl}}/units/1
Authorization: Bearer {{kasirToken}}


# ==========================================
# 4. MANAJEMEN PRODUK
# ==========================================

### Buat Produk Baru (Admin Only)
# @name createProduct
POST {{baseUrl}}/products
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Es Teh Manis",
  "description": "Es teh manis segar",
  "price": 5000,
  "costPrice": 1500,
  "stock": 50,
  "minStock": 10,
  "categoryId": 7,
  "unitId": 3
}

### Ambil ID Produk Yang Baru Dibuat
@productId = {{createProduct.response.body.data.id}}


### List Semua Produk dengan Filter & Pagination
GET {{baseUrl}}/products?page=1&limit=10&search=&lowStock=false
Authorization: Bearer {{kasirToken}}


### Detail Produk Berdasarkan ID
GET {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{kasirToken}}


### Update Produk (Admin or Manager)
PUT {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "price": 6000,
  "minStock": 10
}


### Hapus Produk (Admin Only)
DELETE {{baseUrl}}/products/{{productId}}
Authorization: Bearer {{adminToken}}


# ==========================================
# 5. MANAJEMEN STOK
# ==========================================

### Penyesuaian Stok Manual (Admin Only)
POST {{baseUrl}}/stock/adjust
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 20,
  "type": "IN",
  "description": "Kiriman barang masuk baru dari supplier"
}


### Riwayat Keluar Masuk Stok Produk
GET {{baseUrl}}/stock/movements/{{productId}}
Authorization: Bearer {{kasirToken}}


# ==========================================
# 6. TRANSAKSI KASIR (POS)
# ==========================================

### Ambil Metode Pembayaran
# @name getPaymentMethods
GET {{baseUrl}}/payment-methods
Authorization: Bearer {{kasirToken}}

### Ambil ID Metode Pembayaran (Tunai/QRIS/GoPay/OVO/Transfer Bank)
@paymentMethodId = {{getPaymentMethods.response.body.data[0].id}}


### Buat Transaksi Penjualan Baru (Kasir & Admin)
# @name createTransaction
POST {{baseUrl}}/transactions
Authorization: Bearer {{kasirToken}}
Content-Type: application/json

{
  "paidAmount": 50000,
  "paymentMethodId": {{paymentMethodId}},
  "tax": 11,
  "discount": 5000,
  "items": [
    {
      "productId": {{productId}},
      "quantity": 2,
      "discount": 1000
    }
  ]
}

### Ambil ID Transaksi Baru
@transactionId = {{createTransaction.response.body.data.id}}


### List Riwayat Transaksi
GET {{baseUrl}}/transactions?page=1&limit=10
Authorization: Bearer {{kasirToken}}


### Detail Transaksi Berdasarkan ID
GET {{baseUrl}}/transactions/{{transactionId}}
Authorization: Bearer {{kasirToken}}


# ==========================================
# 7. DASHBOARD (Admin Only)
# ==========================================

### Ringkasan Statistik Dashboard
GET {{baseUrl}}/dashboard/summary
Authorization: Bearer {{adminToken}}


### Tren Grafik Penjualan Harian
GET {{baseUrl}}/dashboard/sales-trend?days=7
Authorization: Bearer {{adminToken}}


### Daftar Produk Terlaris
GET {{baseUrl}}/dashboard/top-products?limit=5
Authorization: Bearer {{adminToken}}


# ==========================================
# 8. LAPORAN (Admin Only)
# ==========================================

### Laporan Penjualan
GET {{baseUrl}}/reports/sales?startDate=2026-06-01&endDate=2026-06-09
Authorization: Bearer {{adminToken}}


### Laporan Produk
GET {{baseUrl}}/reports/products
Authorization: Bearer {{adminToken}}


### Laporan Stok
GET {{baseUrl}}/reports/stock
Authorization: Bearer {{adminToken}}


# ==========================================
# 9. MANAJEMEN USERS (Admin Only)
# ==========================================

### Buat Manager Baru
# @name createManager
POST {{baseUrl}}/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Budi Santoso",
  "email": "budi@warmindo.com",
  "password": "password123",
  "roleId": 2,
  "outletId": 1
}


### Buat Kasir Baru
# @name createCashier
POST {{baseUrl}}/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Siti Rahmawati",
  "email": "siti@warmindo.com",
  "password": "password123",
  "roleId": 3,
  "outletId": 1
}


### List Semua Users
GET {{baseUrl}}/users?page=1&limit=10
Authorization: Bearer {{adminToken}}


# ==========================================
# 10. MASTER ADD-ON (Admin Only)
# ==========================================

### Buat Add-On Baru
# @name createAddOn
POST {{baseUrl}}/add-ons
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Extra Sambal",
  "price": 2000,
  "description": "Tambahan sambal terasi"
}

### Ambil ID Add-On Yang Baru Dibuat
@addOnId = {{createAddOn.response.body.data.id}}


### List Semua Add-On
GET {{baseUrl}}/add-ons
Authorization: Bearer {{kasirToken}}


### Detail Add-On Berdasarkan ID
GET {{baseUrl}}/add-ons/{{addOnId}}
Authorization: Bearer {{kasirToken}}


### Update Add-On (Admin Only)
PUT {{baseUrl}}/add-ons/{{addOnId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Extra Sambal Terasi",
  "price": 3000,
  "description": "Tambahan sambal terasi pedas"
}


### Hapus Add-On (Admin Only)
DELETE {{baseUrl}}/add-ons/{{addOnId}}
Authorization: Bearer {{adminToken}}
